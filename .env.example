# --- Clés API ---
GEMINI_API_KEY=votre_cle_gemini_ici

# --- Configuration Google Drive (Production Vercel) ---
# Copiez le contenu complet de votre fichier service_account.json dans cette variable
GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type": "service_account", "project_id": "...", ...}

# --- Configuration Google Drive (Local) ---
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json
GOOGLE_CREDENTIALS_PATH=./credentials.json
GOOGLE_TOKEN_PATH=./token.pickle

# --- Ressources Drive ---
DRIVE_FOLDER_FICHES=un_id_de_dossier_drive_ici
DRIVE_MODELE_DOC_ID=un_id_de_document_modele_ici

# --- Serveur ---
PORT=5001
MAX_PDF_SIZE_MB=200
