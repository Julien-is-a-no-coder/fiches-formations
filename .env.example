# Variables d'environnement — NE JAMAIS COMMITTER .env

# Clé API Google Gemini (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=votre_cle_api_ici

# Chemin vers le fichier Service Account Google (JSON)
GOOGLE_SERVICE_ACCOUNT_JSON=./service_account.json

# ID du dossier Google Drive cible (fiches de révision)
# https://drive.google.com/drive/folders/1t7JnOY1hO0cMwcCfqLc44eJJ_Mnz--LO
DRIVE_FOLDER_FICHES=1t7JnOY1hO0cMwcCfqLc44eJJ_Mnz--LO

# ID du Google Doc modèle à copier
# https://docs.google.com/document/d/1Ekwki-f3xkUNOyfxd0319GVi7f1g-go6
DRIVE_MODELE_DOC_ID=1Ekwki-f3xkUNOyfxd0319GVi7f1g-go6

# Port du serveur local (défaut : 5001)
PORT=5001

# Taille max upload PDF en MB (défaut : 200)
MAX_PDF_SIZE_MB=200
